# ==================== ASR 转录配置 ====================

# ASR 引擎选择：faster-whisper / funasr / sherpa-onnx
ASR_ENGINE=faster-whisper

# FunASR 备选配置（SenseVoiceSmall / Paraformer 可实验）
# FUNASR_MODEL_TYPE=sensevoice
# FUNASR_MODEL_DIR=/path/to/SenseVoiceSmall
# FUNASR_VAD_DIR=/path/to/speech_fsmn_vad
# Paraformer 可额外配置标点模型
# FUNASR_PUNC_DIR=/path/to/punc_ct-transformer
# 可选：如果主进程未安装 funasr，可指定已安装依赖的 Python 解释器
# FUNASR_PYTHON=./.venv-funasr/Scripts/python.exe
# FUNASR_DEVICE=cuda:0
# FUNASR_LANGUAGE=auto
# FUNASR_USE_ITN=true
# FUNASR_BATCH_SIZE_S=60
# FUNASR_MERGE_VAD=true
# FUNASR_MERGE_LENGTH_S=15
# FUNASR_DISABLE_UPDATE=true
# FUNASR_MAX_SINGLE_SEGMENT_MS=30000
# FUNASR_SUBTITLE_MAX_WORDS=24
# FUNASR_SUBTITLE_MAX_CHARS=64
# 是否过滤首尾边缘噪声段；默认关闭，避免误伤老师课前/课后说明
# FUNASR_FILTER_EDGE_NOISE=false
# 可选：直接写入热词字符串
# FUNASR_HOTWORD=
# 可选：每行一个术语，更适合按课程维护
# FUNASR_HOTWORD_FILE=/path/to/course_hotwords.txt
# 可选：课程热词目录，自动按音频文件名匹配，例如 “机器学习-0411-1055.m4a” -> hotwords/机器学习.txt
# FUNASR_HOTWORD_DIR=./hotwords
# 可选：术语归一化目录，按课程名自动匹配 JSON 规则，只建议修少量高频误识别术语
# TRANSCRIPT_TERM_MAP_DIR=./term_maps
# 可选：保时长的 ASR 音频预处理，默认关闭；建议先做 A/B 再决定是否常开
# 注意：不要把 silenceremove 这类会改时间轴的滤镜直接用于主链 SRT
# ASR_PREPROCESS_AUDIO=false
# ASR_PREPROCESS_FILTERS=highpass,lowpass,loudnorm,afftdn
# ASR_PREPROCESS_HIGHPASS_HZ=80
# ASR_PREPROCESS_LOWPASS_HZ=7600
# ASR_PREPROCESS_AFFTDN_NR=10
# ASR_PREPROCESS_AFFTDN_NF=-40
# 可选：anlmdn 宽带降噪，较慢，建议只做抽样 A/B
# ASR_PREPROCESS_ANLMDN_STRENGTH=0.0001
# ASR_PREPROCESS_ANLMDN_PATCH=0.01
# ASR_PREPROCESS_ANLMDN_RESEARCH=0.006
# ASR_PREPROCESS_ANLMDN_SMOOTH=15
# 可选：arnndn 语音降噪，需要外部 .rnnn 模型文件
# ASR_PREPROCESS_ARNNDN_MODEL=/path/to/ffmpeg-arnndn-models/std.rnnn
# ASR_PREPROCESS_ARNNDN_MIX=0.8
# ASR_PREPROCESS_KEEP_FILES=false
# FUNASR_SAVE_RAW=false

# 本地模型路径（可选）
# FASTWHISPER_LOCAL_DIR=/path/to/model/snapshots/<hash>

# sherpa-onnx 模型目录
# SenseVoice / Paraformer / FireRed CTC 可直接放 model*.onnx + tokens.txt + silero_vad.onnx
# FireRed AED 可放 encoder*.onnx + decoder*.onnx + tokens.txt + silero_vad.onnx
# SHERPA_ONNX_MODEL_DIR=/path/to/sense-voice-or-paraformer-or-firered
# 或者单独指定模型与词表路径
# SHERPA_ONNX_MODEL_PATH=/path/to/model.int8.onnx
# FireRed AED 也可单独指定 encoder / decoder
# SHERPA_ONNX_ENCODER_PATH=/path/to/encoder.int8.onnx
# SHERPA_ONNX_DECODER_PATH=/path/to/decoder.int8.onnx
# SHERPA_ONNX_TOKENS_PATH=/path/to/tokens.txt
# SHERPA_ONNX_VAD_MODEL=/path/to/silero_vad.onnx

# sherpa-onnx 模型类型：sense-voice / paraformer / fire-red-asr / fire-red-asr-ctc
SHERPA_ONNX_MODEL_TYPE=sense-voice

# sherpa-onnx provider：cpu / cuda（取决于你安装的 wheel）
SHERPA_ONNX_PROVIDER=cpu

# sherpa-onnx 线程数
SHERPA_ONNX_NUM_THREADS=2

# sherpa-onnx 是否启用 ITN（SenseVoice 支持）
SHERPA_ONNX_USE_ITN=true

# 设备选择：cuda（GPU）、cpu（CPU）
FASTWHISPER_DEVICE=cuda

# 计算精度：float16（GPU推荐）、int8（CPU推荐）、int8_float16
FASTWHISPER_COMPUTE=float16

# ==================== 性能优化参数 ====================

# Beam Search 大小（默认 3，实测最优配置）
# 建议值：3=最快且准确（推荐）、1=略慢、5=最准确但慢
FASTWHISPER_BEAM_SIZE=3

# Best of 采样数（默认 1，仅在 temperature>0 时有效）
FASTWHISPER_BEST_OF=1

# 提前停止耐心值（默认 1.0，范围 0.5-2.0）
FASTWHISPER_PATIENCE=1.0

# 是否基于前文条件生成（false=更快但可能断句不自然）
FASTWHISPER_CONDITION_PREV=false

# 轻度抑制复读 / 幻觉
FASTWHISPER_REPETITION_PENALTY=1.08
FASTWHISPER_NO_REPEAT_NGRAM_SIZE=3
FASTWHISPER_COMPRESSION_RATIO_THRESHOLD=2.2
FASTWHISPER_LOG_PROB_THRESHOLD=-1.0
FASTWHISPER_NO_SPEECH_THRESHOLD=0.6
FASTWHISPER_HALLUCINATION_SILENCE_THRESHOLD=1.5
FASTWHISPER_DROP_REPEATED_NOISE=true

# ==================== VAD 静音过滤 ====================

# 是否启用 VAD 静音过滤（true=过滤静音段，false=保留所有）
FASTWHISPER_VAD_FILTER=true

# VAD 最小静音长度（毫秒，默认 500ms）
FASTWHISPER_MIN_SILENCE=500

# sherpa-onnx VAD 参数（单位：秒）
SHERPA_ONNX_VAD_THRESHOLD=0.2
SHERPA_ONNX_MIN_SILENCE=0.25
SHERPA_ONNX_MIN_SPEECH=0.25
SHERPA_ONNX_MAX_SPEECH=20
SHERPA_ONNX_VAD_BUFFER_SECONDS=120
SHERPA_ONNX_CHUNK_SECONDS=30

# ==================== 其他参数 ====================

# 采样温度（0=贪心最快，>0=采样更随机）
FASTWHISPER_TEMPERATURE=0

# 初始提示词（可以提高特定词汇识别率，如 "这是一段中文课程音频。"）
# FASTWHISPER_INITIAL_PROMPT=

# 字幕文本最大字符数（超出会截断）
TRANSCRIPT_MAX_CHARS=200000

# 模型缓存目录（如果不使用本地模型时的下载缓存）
# FASTWHISPER_CACHE_DIR=.cache/faster-whisper

# ==================== AI 提供方配置 ====================

# 可选值：google / openai
AI_PROVIDER=openai

# Google Gemini 配置（AI_PROVIDER=google 时使用）
GOOGLE_API_KEY=your_api_key_here

# OpenAI 兼容 API 配置（AI_PROVIDER=openai 时使用）
OPENAI_API_KEY=your_api_key_here
# 如需自定义 OpenAI 兼容服务地址，再取消注释并填写
# OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
OPENAI_MODEL=gemini-3.1-pro-preview-thinking
OPENAI_MAX_RETRIES=3
OPENAI_DISABLE_PROXY=1
OPENAI_TIMEOUT=360

# ==================== 路径配置（可选） ====================

# 下载目录，默认使用仓库内的 data/downloads
# DOWNLOAD_DIR=data/downloads

# Qwen3-ASR 独立测试线（已废弃，仅保留实验记录；不建议并入主线）
# QWEN_ASR_PYTHON=./.venv-qwen-asr/Scripts/python.exe
# QWEN_ASR_MODEL_ROOT=./data/models/qwen3-asr
# QWEN_ASR_MODEL_ID=Qwen/Qwen3-ASR-0.6B
# QWEN_ASR_MODEL_DIR=./data/models/qwen3-asr/Qwen3-ASR-0.6B
# QWEN_ASR_OUTPUT_DIR=./data/benchmarks/qwen-asr-test
# QWEN_ASR_DEVICE_MAP=cuda:0
# QWEN_ASR_DTYPE=float16
# QWEN_ASR_MAX_BATCH_SIZE=4
# QWEN_ASR_MAX_NEW_TOKENS=512

# AI 笔记输出目录，默认使用仓库内的 data/notes
# OBSIDIAN_VAULT_PATH=data/notes

# 临时下载目录，默认使用仓库内的 data/temp
# TEMP_DIR=data/temp

# ==================== 工作流配置 ====================

# 是否默认串行执行任务（推荐开启，避免多任务抢占显卡/磁盘）
SERIAL_TASK_EXECUTION=1

# 仅在 SERIAL_TASK_EXECUTION=0 时生效
WORKER_COUNT=4
